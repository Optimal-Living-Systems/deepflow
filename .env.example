DEEPFLOW_HOST=127.0.0.1
DEEPFLOW_PORT=8011
# Set this to require Bearer token auth on /invoke and /invoke/stream.
# Leave unset to disable auth (local dev only).
DEEPFLOW_API_KEY=

# Model selection
# Leave DEEPFLOW_MODEL unset to auto-pick from available provider keys.
# Examples:
# DEEPFLOW_MODEL=anthropic:claude-sonnet-4-6
# DEEPFLOW_MODEL=openai:gpt-4.1
# DEEPFLOW_MODEL=google_genai:gemini-2.5-pro
# DEEPFLOW_MODEL=openrouter:anthropic/claude-sonnet-4.5
# DEEPFLOW_MODEL=deepseek:deepseek-chat
# DEEPFLOW_MODEL=ollama:qwen3:latest
DEEPFLOW_MODEL=anthropic:claude-sonnet-4-6

# Provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
TAVILY_API_KEY=

# Optional tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deepflow
