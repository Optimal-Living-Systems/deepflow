# Deep Flo Configuration
# Copy this file to .env and fill in your values.

# ─── Required: At least one LLM provider API key ─────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── Deep Flo Runtime Settings ────────────────────────────────
# Model identifier (format: provider:model-name)
DEEP_FLO_MODEL=anthropic:claude-sonnet-4-20250514

# Runtime server port
DEEP_FLO_PORT=8100

# Maximum agent loop iterations per request
DEEP_FLO_MAX_STEPS=50

# Request timeout in seconds
DEEP_FLO_TIMEOUT=300

# Logging level (DEBUG, INFO, WARNING, ERROR)
DEEP_FLO_LOG_LEVEL=INFO

# ─── Langflow Settings (Docker only) ─────────────────────────
LANGFLOW_PORT=7860

# ─── Optional: LangSmith Tracing ─────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=deep-flo
